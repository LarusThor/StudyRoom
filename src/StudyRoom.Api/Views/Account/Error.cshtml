@{
    ViewData["Title"] = "Error";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    .status-wrap {
        min-height: calc(100vh - 140px);
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 1rem;
    }
    .status-card {
        background: #fff;
        border: 1px solid var(--sr-border);
        border-radius: 20px;
        box-shadow: 0 4px 32px rgba(0,0,0,0.07);
        width: 100%;
        max-width: 440px;
        padding: 3rem 2.5rem;
        text-align: center;
    }
    .status-icon {
        width: 72px;
        height: 72px;
        border-radius: 50%;
        background: #fef2f2;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 1.5rem;
    }
    .status-icon i { font-size: 2rem; color: var(--sr-danger); }
    .status-title { font-size: 1.4rem; font-weight: 700; margin-bottom: 0.75rem; }
    .status-body { font-size: 0.9rem; color: var(--sr-muted); line-height: 1.6; margin-bottom: 2rem; }
    .btn-danger-outline {
        border: 1.5px solid var(--sr-danger);
        color: var(--sr-danger);
        background: transparent;
        border-radius: 10px;
        font-weight: 600;
        padding: 0.65rem 1.5rem;
        text-decoration: none;
        transition: all 0.2s;
        display: inline-block;
    }
    .btn-danger-outline:hover {
        background: var(--sr-danger);
        color: #fff;
        transform: translateY(-1px);
    }
</style>

<div class="status-wrap">
    <div class="status-card">
        <div class="status-icon"><i class="bi bi-x-circle-fill"></i></div>
        <h1 class="status-title">Something went wrong</h1>
        <p class="status-body">
            An unexpected error occurred. Please try again later.<br>
            If the problem persists, contact support.
        </p>
        <a asp-action="Login" asp-controller="Account" class="btn-danger-outline">
            <i class="bi bi-arrow-left me-1"></i> Back to Sign In
        </a>
    </div>
</div>
