@model StudyRoom.Api.ViewModels.ProfileViewModel

@{
    ViewData["Title"] = "My Profile";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    .profile-wrap {
        max-width: 700px;
        margin: 0 auto;
        padding: 0 1rem;
    }
    .profile-header {
        background: linear-gradient(135deg, var(--sr-primary) 0%, var(--sr-primary-light) 100%);
        border-radius: 20px 20px 0 0;
        padding: 2rem;
        text-align: center;
        color: #fff;
    }
    .profile-avatar {
        width: 80px;
        height: 80px;
        border-radius: 50%;
        background: rgba(255,255,255,0.2);
        border: 3px solid rgba(255,255,255,0.4);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 2rem;
        font-weight: 700;
        color: #fff;
        margin: 0 auto 1rem;
    }
    .profile-name { font-size: 1.4rem; font-weight: 700; margin-bottom: 0.25rem; }
    .profile-email { font-size: 0.875rem; opacity: 0.8; }
    .profile-body {
        background: #fff;
        border: 1px solid var(--sr-border);
        border-top: none;
        border-radius: 0 0 20px 20px;
        padding: 2rem;
    }
    .info-row {
        display: flex;
        align-items: center;
        padding: 0.85rem 0;
        border-bottom: 1px solid var(--sr-border);
        gap: 1rem;
    }
    .info-row:last-child { border-bottom: none; }
    .info-icon {
        width: 36px;
        height: 36px;
        border-radius: 10px;
        background: var(--sr-surface);
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
        color: var(--sr-primary);
    }
    .info-label { font-size: 0.78rem; color: var(--sr-muted); font-weight: 500; margin-bottom: 0.1rem; }
    .info-value { font-size: 0.925rem; font-weight: 500; color: var(--sr-text); }
    .profile-actions { display: flex; gap: 0.75rem; margin-top: 1.75rem; }
    .btn-action {
        flex: 1;
        border-radius: 10px;
        font-weight: 600;
        font-size: 0.875rem;
        padding: 0.65rem 1rem;
        text-align: center;
        text-decoration: none;
        border: 1.5px solid;
        transition: all 0.2s;
        display: inline-block;
    }
    .btn-action-primary {
        background: var(--sr-primary);
        border-color: var(--sr-primary);
        color: #fff;
    }
    .btn-action-primary:hover {
        background: var(--sr-primary-dark);
        border-color: var(--sr-primary-dark);
        color: #fff;
        transform: translateY(-1px);
    }
    .btn-action-outline {
        background: transparent;
        border-color: var(--sr-border);
        color: var(--sr-text);
    }
    .btn-action-outline:hover {
        border-color: var(--sr-primary);
        color: var(--sr-primary);
        transform: translateY(-1px);
    }
</style>

<div class="profile-wrap">
    <div class="profile-header">
        <div class="profile-avatar">@Model.FirstName.Substring(0, 1).ToUpper()</div>
        <div class="profile-name">@Model.FirstName @Model.LastName</div>
        <div class="profile-email">@Model.Email</div>
    </div>

    <div class="profile-body">
        <div class="info-row">
            <div class="info-icon"><i class="bi bi-person"></i></div>
            <div>
                <div class="info-label">Username</div>
                <div class="info-value">@(Model.UserName ?? "-")</div>
            </div>
        </div>
        <div class="info-row">
            <div class="info-icon"><i class="bi bi-telephone"></i></div>
            <div>
                <div class="info-label">Phone number</div>
                <div class="info-value">@(Model.PhoneNumber ?? "-")</div>
            </div>
        </div>
        <div class="info-row">
            <div class="info-icon"><i class="bi bi-calendar3"></i></div>
            <div>
                <div class="info-label">Date of birth</div>
                <div class="info-value">@(Model.DateOfBirth.HasValue ? Model.DateOfBirth.Value.ToString("dd MMM yyyy") : "-")</div>
            </div>
        </div>
        <div class="info-row">
            <div class="info-icon"><i class="bi bi-clock-history"></i></div>
            <div>
                <div class="info-label">Last sign in</div>
                <div class="info-value">@(Model.LastLoggedIn.HasValue ? Model.LastLoggedIn.Value.ToString("dd MMM yyyy, hh:mm tt") : "-")</div>
            </div>
        </div>
        <div class="info-row">
            <div class="info-icon"><i class="bi bi-shield-check"></i></div>
            <div>
                <div class="info-label">Member since</div>
                <div class="info-value">@(Model.CreatedOn.HasValue ? Model.CreatedOn.Value.ToString("dd MMM yyyy") : "-")</div>
            </div>
        </div>

        <div class="profile-actions">
            <a asp-action="EditProfile" class="btn-action btn-action-primary">
                <i class="bi bi-pencil me-1"></i> Edit Profile
            </a>
            <a asp-action="ChangePassword" class="btn-action btn-action-outline">
                <i class="bi bi-key me-1"></i> Change Password
            </a>
        </div>
    </div>
</div>
