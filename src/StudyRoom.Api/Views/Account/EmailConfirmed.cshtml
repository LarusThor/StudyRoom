@{
    ViewData["Title"] = "Email Confirmed";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    .status-wrap {
        min-height: calc(100vh - 140px);
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 1rem;
    }
    .status-card {
        background: #fff;
        border: 1px solid var(--sr-border);
        border-radius: 20px;
        box-shadow: 0 4px 32px rgba(0,0,0,0.07);
        width: 100%;
        max-width: 440px;
        padding: 3rem 2.5rem;
        text-align: center;
    }
    .status-icon {
        width: 72px;
        height: 72px;
        border-radius: 50%;
        background: #f0fdf4;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 1.5rem;
    }
    .status-icon i { font-size: 2rem; color: #16a34a; }
    .status-title { font-size: 1.4rem; font-weight: 700; margin-bottom: 0.75rem; }
    .status-body { font-size: 0.9rem; color: var(--sr-muted); line-height: 1.6; margin-bottom: 2rem; }
</style>

<div class="status-wrap">
    <div class="status-card">
        <div class="status-icon"><i class="bi bi-patch-check-fill"></i></div>
        <h1 class="status-title">You're all set!</h1>
        <p class="status-body">
            Your email has been verified and your <strong>StudyRoom</strong> account is now active.
            You can sign in and start exploring.
        </p>
        <a asp-action="Login" class="btn btn-primary px-4">Sign In to Your Account</a>
    </div>
</div>
