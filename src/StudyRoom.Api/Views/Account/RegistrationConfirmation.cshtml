@{
    ViewData["Title"] = "Check Your Email";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    .status-wrap {
        min-height: calc(100vh - 140px);
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 1rem;
    }
    .status-card {
        background: #fff;
        border: 1px solid var(--sr-border);
        border-radius: 20px;
        box-shadow: 0 4px 32px rgba(0,0,0,0.07);
        width: 100%;
        max-width: 460px;
        padding: 3rem 2.5rem;
        text-align: center;
    }
    .status-icon {
        width: 72px;
        height: 72px;
        border-radius: 50%;
        background: #f0fdf4;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 1.5rem;
    }
    .status-icon i { font-size: 2rem; color: var(--sr-success); }
    .status-title { font-size: 1.4rem; font-weight: 700; margin-bottom: 0.75rem; }
    .status-body { font-size: 0.9rem; color: var(--sr-muted); line-height: 1.6; margin-bottom: 1.5rem; }
    .info-chip {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        background: #eff6ff;
        color: #1d4ed8;
        border-radius: 20px;
        padding: 0.5rem 1rem;
        font-size: 0.82rem;
        font-weight: 500;
        margin-bottom: 2rem;
    }
</style>

<div class="status-wrap">
    <div class="status-card">
        <div class="status-icon"><i class="bi bi-envelope-check-fill"></i></div>
        <h1 class="status-title">Check your email</h1>
        <p class="status-body">
            We've sent a confirmation link to your inbox.<br>
            Click it to activate your account and get started.
        </p>
        <div class="info-chip">
            <i class="bi bi-info-circle"></i>
            Can't find it? Check your spam or junk folder.
        </div>
        <a asp-action="Login" class="btn btn-primary px-4">Go to Sign In</a>
        <p class="mt-3 mb-0" style="font-size:0.8rem;color:var(--sr-muted);">
            Wrong email? <a asp-action="ResendEmailConfirmation" style="color:var(--sr-primary);font-weight:600;text-decoration:none;">Resend confirmation</a>
        </p>
    </div>
</div>
