@model StudyRoom.Api.ViewModels.ResendConfirmationEmailViewModel

@{
    ViewData["Title"] = "Resend Confirmation";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    .auth-wrap {
        min-height: calc(100vh - 140px);
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 1rem;
    }
    .auth-card {
        background: #fff;
        border: 1px solid var(--sr-border);
        border-radius: 20px;
        box-shadow: 0 4px 32px rgba(0,0,0,0.08);
        width: 100%;
        max-width: 420px;
        padding: 2.5rem;
    }
    .auth-icon {
        width: 52px;
        height: 52px;
        background: linear-gradient(135deg, var(--sr-primary), var(--sr-primary-light));
        border-radius: 14px;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 1.25rem;
    }
    .auth-icon i { color: #fff; font-size: 1.5rem; }
    .auth-title { font-size: 1.4rem; font-weight: 700; text-align: center; margin-bottom: 0.25rem; }
    .auth-sub { font-size: 0.875rem; color: var(--sr-muted); text-align: center; margin-bottom: 1.75rem; }
    .input-wrap { position: relative; }
    .input-wrap .bi {
        position: absolute;
        left: 0.85rem;
        top: 50%;
        transform: translateY(-50%);
        color: var(--sr-muted);
        pointer-events: none;
    }
    .input-wrap .form-control { padding-left: 2.5rem; }
    .auth-link { color: var(--sr-primary); font-weight: 600; text-decoration: none; }
    .auth-link:hover { text-decoration: underline; }
</style>

<div class="auth-wrap">
    <div class="auth-card">
        <div class="auth-icon"><i class="bi bi-envelope-arrow-up-fill"></i></div>
        <h1 class="auth-title">Resend confirmation</h1>
        <p class="auth-sub">Enter your email and we'll send a new confirmation link</p>

        @if (!ViewData.ModelState.IsValid)
        {
            <div class="alert alert-danger mb-3">
                <i class="bi bi-exclamation-circle me-2"></i>Please enter a valid email address.
            </div>
        }

        <form asp-action="ResendEmailConfirmation" method="post" novalidate>
            <div class="mb-4">
                <label asp-for="Email" class="form-label">Email address</label>
                <div class="input-wrap">
                    <i class="bi bi-envelope"></i>
                    <input asp-for="Email" class="form-control" placeholder="you@example.com" />
                </div>
                <span asp-validation-for="Email" class="text-danger" style="font-size:0.8rem;"></span>
            </div>
            <button type="submit" class="btn-primary w-100 mb-3">Send Confirmation Email</button>
        </form>

        <p class="text-center mb-0" style="font-size:0.85rem;color:var(--sr-muted);">
            Remember your password? <a class="auth-link" asp-action="Login">Sign in</a>
        </p>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
