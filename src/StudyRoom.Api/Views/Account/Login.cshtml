@model StudyRoom.Api.ViewModels.LoginViewModel

@{
    ViewData["Title"] = "Sign In";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    .auth-wrap {
        min-height: calc(100vh - 140px);
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 1rem;
    }
    .auth-card {
        background: #fff;
        border: 1px solid var(--sr-border);
        border-radius: 20px;
        box-shadow: 0 4px 32px rgba(0,0,0,0.08);
        width: 100%;
        max-width: 420px;
        padding: 2.5rem;
    }
    .auth-icon {
        width: 52px;
        height: 52px;
        background: linear-gradient(135deg, var(--sr-primary), var(--sr-primary-light));
        border-radius: 14px;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 1.25rem;
    }
    .auth-icon i { color: #fff; font-size: 1.5rem; }
    .auth-title { font-size: 1.5rem; font-weight: 700; text-align: center; margin-bottom: 0.25rem; }
    .auth-sub { font-size: 0.875rem; color: var(--sr-muted); text-align: center; margin-bottom: 1.75rem; }
    .input-wrap { position: relative; }
    .input-wrap .bi {
        position: absolute;
        left: 0.85rem;
        top: 50%;
        transform: translateY(-50%);
        color: var(--sr-muted);
        pointer-events: none;
    }
    .input-wrap .form-control { padding-left: 2.5rem; }
    .divider {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        color: var(--sr-muted);
        font-size: 0.8rem;
        margin: 1.25rem 0;
    }
    .divider::before, .divider::after { content: ''; flex: 1; height: 1px; background: var(--sr-border); }
    .auth-link { color: var(--sr-primary); font-weight: 600; text-decoration: none; }
    .auth-link:hover { text-decoration: underline; }
    .form-check-input:checked { background-color: var(--sr-primary); border-color: var(--sr-primary); }
</style>

<div class="auth-wrap">
    <div class="auth-card">
        <div class="auth-icon"><i class="bi bi-mortarboard-fill"></i></div>
        <h1 class="auth-title">Welcome back</h1>
        <p class="auth-sub">Sign in to your StudyRoom account</p>

        @if (ViewBag.Message != null)
        {
            <div class="alert alert-info mb-3"><i class="bi bi-info-circle me-2"></i>@ViewBag.Message</div>
        }
        @if (!ViewData.ModelState.IsValid)
        {
            <div class="alert alert-danger mb-3">
                <i class="bi bi-exclamation-circle me-2"></i>
                @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                {<span>@error.ErrorMessage</span>}
            </div>
        }

        <form asp-action="Login" method="post" novalidate>
            <div class="mb-3">
                <label asp-for="Email" class="form-label">Email address</label>
                <div class="input-wrap">
                    <i class="bi bi-envelope"></i>
                    <input asp-for="Email" class="form-control" placeholder="you@example.com" autocomplete="username" />
                </div>
                <span asp-validation-for="Email" class="text-danger" style="font-size:0.8rem;"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Password" class="form-label">Password</label>
                <div class="input-wrap">
                    <i class="bi bi-lock"></i>
                    <input asp-for="Password" class="form-control" type="password" placeholder="••••••••" autocomplete="current-password" />
                </div>
                <span asp-validation-for="Password" class="text-danger" style="font-size:0.8rem;"></span>
            </div>
            <div class="form-check mb-4">
                <input asp-for="RememberMe" class="form-check-input" />
                <label asp-for="RememberMe" class="form-check-label" style="font-size:0.85rem;">Remember me</label>
            </div>
            <button type="submit" class="btn-primary w-100">Sign In</button>
        </form>

        <div class="divider">or</div>

        <p class="text-center mb-1" style="font-size:0.85rem;color:var(--sr-muted);">
            Don't have an account? <a class="auth-link" asp-action="Register">Create one</a>
        </p>
        <p class="text-center mb-0" style="font-size:0.8rem;">
            <a asp-action="ResendEmailConfirmation" style="color:var(--sr-muted);text-decoration:none;">Didn't receive a confirmation email?</a>
        </p>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
