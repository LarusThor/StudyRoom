@model StudyRoom.Api.ViewModels.HomeViewModel

@section Styles {
    <link rel="stylesheet" href="~/css/templatemo-chain-summit.css" />
}

<!-- Background Animation -->
<div class="bg-animation">
    <div class="neural-network" id="neuralNetwork"></div>
    <div class="particles" id="particles"></div>
</div>

<!-- Hero -->
<section id="home" class="hero">
    <div class="hero-content">
        <h1>StudyRoom</h1>
        <p>Your collaborative space for focused learning</p>

        <div class="cta-buttons">
            <a href="@Url.Action("Register", "Account")" class="btn btn-primary">Get Started</a>
            <a href="@Url.Action("Login", "Account")" class="btn btn-secondary">Sign In</a>
        </div>
    </div>
</section>

<!-- About Section -->
<section id="about" class="section">
    <h2 class="animate-on-scroll">About StudyRoom</h2>
    <div class="about-content">
        <div class="about-text animate-on-scroll slide-left">
            <p>StudyRoom is a platform built for students and learners who want a focused, distraction-free environment to study, track progress, and collaborate with others.</p>
            <p>Whether you're preparing for exams, learning a new skill, or working through coursework — StudyRoom keeps you on track.</p>
        </div>
        <div class="about-visual animate-on-scroll slide-right">
            <div class="blockchain-visual">
                <div class="block">Focus</div>
                <div class="block">Learn</div>
                <div class="block">Track</div>
                <div class="block">Grow</div>
                <div class="block">Share</div>
                <div class="block">Win</div>
            </div>
        </div>
    </div>

    <div class="hex-decoration" style="top: 10%; left: 5%;"></div>
    <div class="hex-decoration" style="top: 70%; right: 10%; animation-delay: 2s;"></div>
</section>

@section Scripts {
    <script src="~/js/templatemo-chain-scripts.js"></script>
}
