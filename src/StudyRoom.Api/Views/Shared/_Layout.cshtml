@{
    ViewData["Title"] = ViewData["Title"] ?? "StudyRoom";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>@ViewData["Title"] - StudyRoom</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">

    <style>
        :root {
            --sr-primary:       #4f46e5;
            --sr-primary-dark:  #3730a3;
            --sr-primary-light: #818cf8;
            --sr-surface:       #f1f5f9;
            --sr-card:          #ffffff;
            --sr-text:          #1e293b;
            --sr-muted:         #64748b;
            --sr-border:        #e2e8f0;
            --sr-nav-bg:        #18184a;
        }

        *, *::before, *::after { box-sizing: border-box; }

        body {
            font-family: 'Inter', sans-serif;
            background-color: var(--sr-surface);
            color: var(--sr-text);
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            margin: 0;
        }

        /* ── Navbar ── */
        .sr-navbar {
            background: var(--sr-nav-bg);
            border-bottom: 1px solid rgba(255,255,255,0.06);
            padding: 0.75rem 0;
        }
        .sr-navbar .navbar-brand {
            font-weight: 700;
            font-size: 1.25rem;
            letter-spacing: -0.5px;
            color: #fff;
            text-decoration: none;
        }
        .sr-navbar .navbar-brand span { color: var(--sr-primary-light); }
        .sr-navbar .nav-link {
            color: rgba(255,255,255,0.65) !important;
            font-size: 0.875rem;
            font-weight: 500;
            transition: color 0.15s;
        }
        .sr-navbar .nav-link:hover { color: #fff !important; }

        .btn-nav {
            background: rgba(255,255,255,0.1);
            color: rgba(255,255,255,0.85);
            border: 1px solid rgba(255,255,255,0.15);
            border-radius: 8px;
            padding: 0.4rem 1rem;
            font-size: 0.85rem;
            font-weight: 500;
            text-decoration: none;
            transition: all 0.15s;
            display: inline-block;
        }
        .btn-nav:hover { background: rgba(255,255,255,0.18); color: #fff; }

        .btn-nav-primary {
            background: var(--sr-primary);
            color: #fff;
            border: 1px solid var(--sr-primary);
            border-radius: 8px;
            padding: 0.4rem 1rem;
            font-size: 0.85rem;
            font-weight: 500;
            text-decoration: none;
            transition: all 0.15s;
            display: inline-block;
        }
        .btn-nav-primary:hover { background: var(--sr-primary-dark); color: #fff; }

        .sr-avatar {
            width: 32px;
            height: 32px;
            border-radius: 50%;
            background: var(--sr-primary);
            color: #fff;
            font-size: 0.8rem;
            font-weight: 700;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
        }

        .dropdown-menu {
            border: 1px solid var(--sr-border);
            border-radius: 12px;
            box-shadow: 0 8px 24px rgba(0,0,0,0.1);
            padding: 0.4rem;
        }
        .dropdown-item {
            border-radius: 8px;
            font-size: 0.875rem;
            font-weight: 500;
            padding: 0.5rem 0.75rem;
        }
        .dropdown-item:hover { background: var(--sr-surface); }

        /* ── Buttons ── */
        .btn-primary {
            background: var(--sr-primary);
            border-color: var(--sr-primary);
            border-radius: 10px;
            font-weight: 600;
            font-size: 0.9rem;
            padding: 0.65rem 1.5rem;
            transition: all 0.2s;
        }
        .btn-primary:hover, .btn-primary:focus {
            background: var(--sr-primary-dark);
            border-color: var(--sr-primary-dark);
            transform: translateY(-1px);
            box-shadow: 0 4px 14px rgba(79,70,229,0.35);
        }

        /* ── Form inputs ── */
        .form-control, .form-select {
            border-radius: 10px;
            border: 1.5px solid var(--sr-border);
            padding: 0.65rem 1rem;
            font-size: 0.9rem;
            background: #fff;
            transition: border-color 0.15s, box-shadow 0.15s;
        }
        .form-control:focus, .form-select:focus {
            border-color: var(--sr-primary);
            box-shadow: 0 0 0 3px rgba(79,70,229,0.12);
        }
        .form-label {
            font-weight: 500;
            font-size: 0.85rem;
            color: var(--sr-text);
            margin-bottom: 0.35rem;
        }

        /* ── Alerts ── */
        .alert { border-radius: 10px; font-size: 0.875rem; border: none; }
        .alert-danger  { background: #fef2f2; color: #b91c1c; }
        .alert-success { background: #f0fdf4; color: #15803d; }
        .alert-info    { background: #eff6ff; color: #1d4ed8; }

        /* ── Footer ── */
        .sr-footer {
            background: var(--sr-nav-bg);
            border-top: 1px solid rgba(255,255,255,0.06);
            padding: 1.25rem 0;
        }
        .sr-footer a {
            color: rgba(255,255,255,0.4);
            text-decoration: none;
            font-size: 0.8rem;
            transition: color 0.15s;
        }
        .sr-footer a:hover { color: rgba(255,255,255,0.8); }
        .sr-footer .copy { color: rgba(255,255,255,0.3); font-size: 0.8rem; }

        /* ── Page animation ── */
        @@keyframes fadeUp {
            from { opacity: 0; transform: translateY(10px); }
            to   { opacity: 1; transform: translateY(0); }
        }
        .page-content { animation: fadeUp 0.3s ease-out both; }
    </style>
</head>
<body>

    <nav class="sr-navbar navbar navbar-expand-lg">
        <div class="container">
            <a class="navbar-brand" href="@Url.Action("Login", "Account")">Study<span>Room</span></a>
            <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse"
                    data-bs-target="#navbarContent" aria-controls="navbarContent"
                    aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarContent">
                <ul class="navbar-nav me-auto mb-2 mb-lg-0"></ul>
                <ul class="navbar-nav mb-2 mb-lg-0 gap-2 align-items-center">
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle d-flex align-items-center gap-2" href="#"
                               id="userDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                <span class="sr-avatar">@(User.Identity.Name?.Substring(0, 1).ToUpper())</span>
                                <span style="color:rgba(255,255,255,0.8);font-size:0.875rem;">@User.Identity.Name</span>
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="userDropdown">
                                <li>
                                    <a class="dropdown-item" href="@Url.Action("Profile", "Account")">
                                        <i class="bi bi-person me-2 text-primary"></i>My Profile
                                    </a>
                                </li>
                                <li><hr class="dropdown-divider my-1" /></li>
                                <li>
                                    <form method="post" asp-controller="Account" asp-action="Logout">
                                        <button type="submit" class="dropdown-item text-danger">
                                            <i class="bi bi-box-arrow-right me-2"></i>Sign Out
                                        </button>
                                    </form>
                                </li>
                            </ul>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item">
                            <a class="btn-nav" href="@Url.Action("Login", "Account")">Sign In</a>
                        </li>
                        <li class="nav-item">
                            <a class="btn-nav-primary" href="@Url.Action("Register", "Account")">Get Started</a>
                        </li>
                    }
                </ul>
            </div>
        </div>
    </nav>

    <main class="flex-grow-1 py-4">
        <div class="page-content">
            @RenderBody()
        </div>
    </main>

    <footer class="sr-footer">
        <div class="container d-flex flex-column flex-md-row justify-content-between align-items-center gap-2">
            <span class="copy">&copy; @DateTime.Now.Year StudyRoom. All rights reserved.</span>
            <div class="d-flex gap-3">
                <a href="#">Privacy</a>
                <a href="#">Terms</a>
                <a href="#">Contact</a>
            </div>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
